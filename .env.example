# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Pooled connection used by the app at runtime
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atria?schema=public"
# Direct (non-pooled) connection used by Prisma migrations
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/atria?schema=public"

# ─── Auth (Better Auth) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Payments (Stripe) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Storage (S3-compatible: Cloudflare R2 / AWS S3) ─────────────────────
# For real AWS S3, leave S3_ENDPOINT unset and set S3_REGION to a real region (e.g. "sa-east-1").
# S3_ENDPOINT is only needed for R2/MinIO-style endpoints.
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_PUBLIC="atria-public"
S3_BUCKET_PRIVATE="atria-private"
# Public base URL for the public bucket's objects — a CloudFront domain (recommended) or the
# bucket's own endpoint. Defaults to "${S3_ENDPOINT}/${S3_BUCKET_PUBLIC}" if unset.
S3_PUBLIC_URL=""

# ─── Email (AWS SES) — auth verification / password reset ───────────────
SES_REGION="sa-east-1"
SES_FROM_EMAIL=""
# Same IAM user/access key as the S3_* ones is fine (it just needs ses:SendEmail too).
SES_ACCESS_KEY_ID=""
SES_SECRET_ACCESS_KEY=""
