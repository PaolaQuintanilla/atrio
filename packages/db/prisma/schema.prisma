// Atria — Prisma schema (PostgreSQL)
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

// Stored on User as a plain String for Better Auth compatibility; allowed
// values are enforced in the API layer (see packages/api). Kept here as docs.
enum ListingType {
  RENT
  SALE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  RENTED
  ARCHIVED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum AttributeType {
  TEXT
  NUMBER
  BOOLEAN
  ENUM
  DATE
}

enum DocumentType {
  TITLE_DEED
  DERECHOS_REALES
  ID_DOCUMENT
  VEHICLE_TITLE
  TAX_RECEIPT
  OTHER
}

enum ReviewDecision {
  APPROVED
  REJECTED
}

enum PaymentKind {
  FEATURED_LISTING
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ─────────────────────────────────────────────────────────────────────────
// Auth (Better Auth managed tables)
// ─────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  // Role: "BUYER" | "SELLER" | "ADMIN" (String for Better Auth compatibility)
  role          String   @default("BUYER")
  banned        Boolean  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  sessions      Session[]
  accounts      Account[]
  listings      Listing[]          @relation("SellerListings")
  reviews       VerificationReview[]
  favorites     Favorite[]
  buyerThreads  Conversation[]     @relation("BuyerConversations")
  sellerThreads Conversation[]     @relation("SellerConversations")
  messages      Message[]
  payments      Payment[]
  subscription  Subscription?
  reports       Report[]           @relation("ReporterReports")

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────
// Profiles
// ─────────────────────────────────────────────────────────────────────────

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String?
  phone       String?
  avatarUrl   String?
  locale      String  @default("es")
  country     String?
  city        String?
  bio         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile")
}

// ─────────────────────────────────────────────────────────────────────────
// Dynamic categories & attributes
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  // Translatable label keyed by locale: { "es": "Casas", "en": "Houses" }
  name      Json
  icon      String?
  parentId  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent     Category?             @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]            @relation("CategoryTree")
  attributes AttributeDefinition[]
  listings   Listing[]

  @@index([parentId])
  @@map("category")
}

model AttributeDefinition {
  id         String        @id @default(cuid())
  categoryId String
  key        String // machine key stored in Listing.attributes, e.g. "bedrooms"
  label      Json // translatable label keyed by locale
  type       AttributeType
  unit       String? // e.g. "m²", "km"
  // For ENUM types: [{ "value": "brick", "label": { "es": "...", "en": "..." } }]
  options    Json?
  required   Boolean       @default(false)
  filterable Boolean       @default(true)
  order      Int           @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("attribute_definition")
}

// ─────────────────────────────────────────────────────────────────────────
// Listings
// ─────────────────────────────────────────────────────────────────────────

model Listing {
  id                 String             @id @default(cuid())
  sellerId           String
  categoryId         String
  type               ListingType
  status             ListingStatus      @default(DRAFT)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  title              String
  description        String
  price              Decimal            @db.Decimal(14, 2)
  currency           String             @default("USD")
  // Dynamic attribute values validated against the category's definitions
  attributes         Json               @default("{}")
  country            String?
  city               String?
  address            String?
  lat                Float?
  lng                Float?
  sourceLocale       String             @default("es")
  isFeatured         Boolean            @default(false)
  featuredUntil      DateTime?
  viewCount          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  seller        User                 @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  category      Category             @relation(fields: [categoryId], references: [id])
  media         ListingMedia[]
  documents     ListingDocument[]
  reviews       VerificationReview[]
  favorites     Favorite[]
  conversations Conversation[]
  payments      Payment[]
  reports       Report[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([type])
  @@index([verificationStatus])
  @@index([country, city])
  @@map("listing")
}

model ListingMedia {
  id        String   @id @default(cuid())
  listingId String
  url       String
  key       String // object storage key (public bucket)
  order     Int      @default(0)
  isCover   Boolean  @default(false)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_media")
}

model ListingDocument {
  id                 String             @id @default(cuid())
  listingId          String
  type               DocumentType
  key                String // object storage key (PRIVATE bucket — signed-URL access only)
  fileName           String
  mimeType           String
  sizeBytes          Int
  verificationStatus VerificationStatus @default(PENDING)
  uploadedAt         DateTime           @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_document")
}

model VerificationReview {
  id         String         @id @default(cuid())
  listingId  String
  reviewerId String
  decision   ReviewDecision
  notes      String?
  createdAt  DateTime       @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([listingId])
  @@index([reviewerId])
  @@map("verification_review")
}

// ─────────────────────────────────────────────────────────────────────────
// Engagement: favorites, messaging
// ─────────────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
  @@map("favorite")
}

model Conversation {
  id            String   @id @default(cuid())
  listingId     String
  buyerId       String
  sellerId      String
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("conversation")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("message")
}

// ─────────────────────────────────────────────────────────────────────────
// Payments (Stripe)
// ─────────────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  listingId             String?
  kind                  PaymentKind
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(14, 2)
  currency              String        @default("USD")
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("payment")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  status               String    @default("inactive")
  plan                 String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  listingId  String
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())

  reporter User    @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("report")
}
